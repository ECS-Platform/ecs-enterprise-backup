# ECS environment template — .env.prod
# =============================================================================
# PLACEHOLDERS ONLY. Copy to `.env.prod`, replace every <...>, and NEVER commit
# the populated file (.gitignore already blocks .env.* except .env.example).
# Source secrets from a managed secret store in production; do not paste real
# IPs, hostnames, tokens, or passwords into any committed file.
# =============================================================================

ECS_ENV=prod

# --- Core runtime ------------------------------------------------
# ECS process/runtime settings (non-secret).
# Enable auth/RBAC (true in real environments).
ECS_AUTH_ENABLED=true
# Config validation mode (on | warn | off).
ECS_VALIDATE_CONFIG=on

# --- Audit persistence (Postgres) --------------------------------
# Durable audit-intelligence store. Provision Postgres and apply docs/DB_SCHEMA_AUDIT_INTELLIGENCE.sql. Source the URL from a secret manager.
# SQLAlchemy/psycopg URL, e.g. postgresql://<user>:<pw>@<host>:5432/<db>. Contains a credential -> treat as a secret.
ECS_AUDIT_DB_URL=<do-not-commit>

# --- Oracle ------------------------------------------------------
# Read-only service account for Oracle baselining checks.
# Oracle host or FQDN (no real value in Git).
ECS_ORACLE_HOST=<uat-oracle-host>
# Oracle listener port.
ECS_ORACLE_PORT=1521
# Oracle service name.
ECS_ORACLE_SERVICE_NAME=<service-name>
# Read-only service account.
ECS_ORACLE_USER=<service-account>
# Oracle password.
ECS_ORACLE_PASSWORD=<do-not-commit>
# Request timeout (seconds).
ECS_ORACLE_TIMEOUT_SECONDS=30

# --- PostgreSQL --------------------------------------------------
# Read-only service account for PostgreSQL checks.
# PostgreSQL host or FQDN.
ECS_PG_HOST=<uat-postgres-host>
# PostgreSQL port.
ECS_PG_PORT=5432
# Database name.
ECS_PG_DATABASE=<database>
# Read-only service account.
ECS_PG_USER=<service-account>
# PostgreSQL password.
ECS_PG_PASSWORD=<do-not-commit>
# TLS mode (require in real envs).
ECS_PG_SSLMODE=require
# Request timeout (seconds).
ECS_PG_TIMEOUT_SECONDS=30

# --- YugabyteDB --------------------------------------------------
# Read-only service account for YugabyteDB (PG wire).
# Yugabyte host or FQDN.
ECS_YB_HOST=<uat-yugabyte-host>
# Yugabyte YSQL port.
ECS_YB_PORT=5433
# Database name.
ECS_YB_DATABASE=<database>
# Read-only service account.
ECS_YB_USER=<service-account>
# Yugabyte password.
ECS_YB_PASSWORD=<do-not-commit>
# TLS mode.
ECS_YB_SSLMODE=require
# Request timeout (seconds).
ECS_YB_TIMEOUT_SECONDS=30

# --- MySQL / Aurora ----------------------------------------------
# Read-only account for MySQL / Aurora-MySQL (wire-compatible).
# MySQL/Aurora host or FQDN.
ECS_MYSQL_HOST=<uat-mysql-host>
# MySQL port.
ECS_MYSQL_PORT=3306
# Database name.
ECS_MYSQL_DATABASE=<database>
# Read-only service account.
ECS_MYSQL_USER=<service-account>
# MySQL password.
ECS_MYSQL_PASSWORD=<do-not-commit>
# Require TLS (true in real envs).
ECS_MYSQL_SSL=true
# Request timeout (seconds).
ECS_MYSQL_TIMEOUT_SECONDS=30

# --- SQL Server --------------------------------------------------
# Read-only service account for SQL Server checks.
# SQL Server host or FQDN.
ECS_SQLSERVER_HOST=<uat-sqlserver-host>
# SQL Server port.
ECS_SQLSERVER_PORT=1433
# Database name.
ECS_SQLSERVER_DATABASE=<database>
# Read-only service account.
ECS_SQLSERVER_USERNAME=<service-account>
# SQL Server password.
ECS_SQLSERVER_PASSWORD=<do-not-commit>
# Request timeout (seconds).
ECS_SQLSERVER_TIMEOUT_SECONDS=30

# --- MongoDB -----------------------------------------------------
# Connection URI may embed credentials -> treat as secret.
# Mongo URI, e.g. mongodb://<user>:<pw>@<host>:27017/?authSource=admin.
ECS_MONGODB_URI=<do-not-commit>
# Database name.
ECS_MONGODB_DATABASE=admin
# Request timeout (seconds).
ECS_MONGODB_TIMEOUT_SECONDS=30

# --- Redis -------------------------------------------------------
# Redis endpoint (password optional depending on deployment).
# Redis host or FQDN.
ECS_REDIS_HOST=<uat-redis-host>
# Redis port.
ECS_REDIS_PORT=6379
# Redis password (blank if none).
ECS_REDIS_PASSWORD=<do-not-commit>
# Request timeout (seconds).
ECS_REDIS_TIMEOUT_SECONDS=30

# --- Linux / RHEL / NGINX / Apache / Tomcat ----------------------
# OS + middleware targets (roadmap SSH mode; use read-only accounts).
# Linux/RHEL host or FQDN.
ECS_LINUX_HOST=<uat-linux-host>
# SSH service account.
ECS_LINUX_USERNAME=<ssh-service-account>
# Auth mode (key | password).
ECS_LINUX_AUTH_MODE=key
# Path to the SSH private key (never commit the key).
ECS_SSH_KEY_PATH=<path-to-private-key>
# NGINX host or FQDN.
ECS_NGINX_HOST=<uat-nginx-host>
# Apache host or FQDN.
ECS_APACHE_HOST=<uat-apache-host>
# Tomcat host or FQDN.
ECS_TOMCAT_HOST=<uat-tomcat-host>

# --- Kubernetes --------------------------------------------------
# Read-only cluster access via kubeconfig.
# kubectl binary path.
ECS_KUBECTL_PATH=kubectl
# Path to the UAT/prod kubeconfig (never commit it).
ECS_KUBECONFIG=<path-to-kubeconfig>
# Request timeout (seconds).
ECS_K8S_TIMEOUT_SECONDS=30

# --- OpenShift ---------------------------------------------------
# Read-only cluster access via kubeconfig / oc.
# oc binary path.
ECS_OC_PATH=oc
# Path to the OpenShift kubeconfig (never commit it).
ECS_OPENSHIFT_KUBECONFIG=<path-to-kubeconfig>
# Request timeout (seconds).
ECS_OPENSHIFT_TIMEOUT_SECONDS=30

# --- ServiceNow CMDB ---------------------------------------------
# OAuth client-credentials for CMDB asset discovery.
# Instance URL, e.g. https://<instance>.service-now.com.
ECS_SERVICENOW_BASE_URL=https://<instance>.service-now.com
# OAuth client id.
ECS_SERVICENOW_CLIENT_ID=<do-not-commit>
# OAuth client secret.
ECS_SERVICENOW_CLIENT_SECRET=<do-not-commit>
# Request timeout (seconds).
ECS_SERVICENOW_TIMEOUT_SECONDS=30

# --- Archer ------------------------------------------------------
# API token for Archer GRC.
# Archer base URL.
ECS_ARCHER_BASE_URL=https://<uat-archer-host>
# Archer API token.
ECS_ARCHER_API_TOKEN=<do-not-commit>
# Request timeout (seconds).
ECS_ARCHER_TIMEOUT_SECONDS=30

# --- SharePoint / Microsoft Graph --------------------------------
# OAuth client-credentials for evidence documents.
# Azure AD tenant id.
ECS_GRAPH_TENANT_ID=<do-not-commit>
# App registration client id.
ECS_GRAPH_CLIENT_ID=<do-not-commit>
# App registration client secret.
ECS_GRAPH_CLIENT_SECRET=<do-not-commit>
# Target SharePoint site id.
ECS_GRAPH_SITE_ID=<site-id>
# Optional drive id.
ECS_GRAPH_DRIVE_ID=<drive-id-optional>
# Request timeout (seconds).
ECS_GRAPH_TIMEOUT_SECONDS=30

# --- Jira --------------------------------------------------------
# Basic auth (email + API token).
# Jira base URL.
ECS_JIRA_BASE_URL=https://<org>.atlassian.net
# Jira account email.
ECS_JIRA_USERNAME=<service-account-email>
# Jira API token.
ECS_JIRA_API_TOKEN=<do-not-commit>
# Request timeout (seconds).
ECS_JIRA_TIMEOUT_SECONDS=30

# --- Confluence --------------------------------------------------
# Basic auth (email + API token).
# Confluence base URL.
ECS_CONFLUENCE_BASE_URL=https://<org>.atlassian.net/wiki
# Confluence account email.
ECS_CONFLUENCE_USERNAME=<service-account-email>
# Confluence API token.
ECS_CONFLUENCE_API_TOKEN=<do-not-commit>
# Request timeout (seconds).
ECS_CONFLUENCE_TIMEOUT_SECONDS=30

# --- SonarQube ---------------------------------------------------
# Token auth (AppSec quality-gate / issue evidence).
# SonarQube base URL.
ECS_SONARQUBE_BASE_URL=https://<uat-sonarqube-host>
# SonarQube user token.
ECS_SONARQUBE_TOKEN=<do-not-commit>
# Request timeout (seconds).
ECS_SONARQUBE_TIMEOUT_SECONDS=30

# --- Checkmarx ---------------------------------------------------
# OAuth client-credentials (SAST scan evidence).
# Checkmarx base URL.
ECS_CHECKMARX_BASE_URL=https://<uat-checkmarx-host>
# Checkmarx client id.
ECS_CHECKMARX_CLIENT_ID=<do-not-commit>
# Checkmarx client secret.
ECS_CHECKMARX_CLIENT_SECRET=<do-not-commit>
# Request timeout (seconds).
ECS_CHECKMARX_TIMEOUT_SECONDS=30

# --- Prisma Cloud ------------------------------------------------
# Access-key / secret-key (cloud posture / compliance).
# Prisma Cloud API URL.
ECS_PRISMA_CLOUD_BASE_URL=https://<api-region>.prismacloud.io
# Prisma Cloud access key.
ECS_PRISMA_CLOUD_ACCESS_KEY=<do-not-commit>
# Prisma Cloud secret key.
ECS_PRISMA_CLOUD_SECRET_KEY=<do-not-commit>
# Request timeout (seconds).
ECS_PRISMA_CLOUD_TIMEOUT_SECONDS=30

# --- Tripwire ----------------------------------------------------
# Basic auth (username + password) for file-integrity evidence.
# Tripwire base URL.
ECS_TRIPWIRE_BASE_URL=https://<uat-tripwire-host>
# Tripwire service account.
ECS_TRIPWIRE_USERNAME=<service-account>
# Tripwire password.
ECS_TRIPWIRE_PASSWORD=<do-not-commit>
# Request timeout (seconds).
ECS_TRIPWIRE_TIMEOUT_SECONDS=30
