# =============================================================================
# ECS DISASTER RECOVERY (DR) — Deployment Environment Variables (EXAMPLE)
# =============================================================================
# Copy to a git-ignored `.env.dr` (or inject via the DR vault / K8s secrets):
#     cp .env.dr.example .env.dr
#
# DR mirrors PRODUCTION on the secondary site — same variables, DR-site hosts.
# Moving PROD→DR requires ONLY changing the host/endpoint values here (and
# pointing ECS_ENV=dr) — never source code.
#
# SAFETY: placeholders only. NEVER commit real secrets/hosts/IPs. `.env.dr` must
# be git-ignored. Validate before failover:
#     ECS_ENV=dr ECS_VALIDATE_SECRETS=1 \
#         python -m config.config_validation dr --check-secrets
# =============================================================================

# ---- Environment selector ----
ECS_ENV=dr

# ---- Security mode (STRICT — DR mirrors production) ----
# DR inherits production strictness. Do NOT relax these on the DR site. Live
# connector execution remains opt-in. See docs/operations/PROTOTYPE_DEMO_RUN_MODE.md.
ECS_SECURITY_MODE=production
ECS_AUTH_ENABLED=true
ECS_RBAC_ENFORCEMENT=true
ECS_REQUIRE_TLS=true
ECS_REQUIRE_SECRETS=true
ECS_REQUIRE_OIDC=true
ECS_ALLOW_IN_MEMORY=false
ECS_STRICT_CONFIG_VALIDATION=true
ECS_STARTUP_FAIL_ON_CONFIG_ERROR=true
ECS_CONNECTOR_EXECUTION_ENABLED=false

# ---- ECS application identity (DR site; must NOT be localhost) ----
ECS_HOST=0.0.0.0
ECS_PORT=8000
ECS_PUBLIC_URL=https://ecs.dr.bank.internal
ECS_BASE_URL=https://ecs.dr.bank.internal
ECS_WEB_WORKERS=4

# ---- Security / TLS (DR can be promoted to serve production) ----
ECS_AUTH_ENABLED=true
ECS_LOCAL_AUTH_BYPASS=false
ECS_FORCE_HTTPS=true
ECS_HSTS_ENABLED=true
ECS_SSO_ENABLED=true
ECS_SSO_PROVIDER=saml

# ---- Evidence repository (PostgreSQL, DR replica/standby) ----
ECS_REPO_PG_HOST=pg.dr.bank.internal
ECS_REPO_PG_PORT=5432
ECS_REPO_PG_DATABASE=ecs_repository
ECS_REPO_PG_USER=ecs_user
ECS_REPO_PG_PASSWORD=<from-dr-vault>
ECS_REPO_PG_SCHEMA=public

# ---- Redis (DR site) ----
REDIS_HOST=redis.dr.bank.internal
REDIS_PORT=6379
REDIS_SSL=true
REDIS_PASSWORD=<from-dr-vault>

# ---- Object storage (DR bucket / replicated) ----
ECS_OBJECT_STORE_ENABLED=true
ECS_OBJECT_STORE_PROVIDER=s3
MINIO_ENDPOINT=objectstore.dr.bank.internal:9000
MINIO_BUCKET=ecs-evidence-dr
MINIO_SECURE=true
MINIO_ACCESS_KEY=<from-dr-vault>
MINIO_SECRET_KEY=<from-dr-vault>

# ---- Vector store (DR site) ----
ECS_VECTOR_PROVIDER=pgvector
ECS_VECTOR_PG_HOST=pgvector.dr.bank.internal
ECS_VECTOR_PG_PORT=5432
ECS_VECTOR_PG_DATABASE=ecs_vectors
ECS_VECTOR_PG_PASSWORD=<from-dr-vault>

# ---- LLM / embeddings (DR-site on-prem inference) ----
ECS_LLM_PROVIDER=ollama
ECS_LLM_MODEL=qwen3:8b
OLLAMA_URL=http://llm.dr.bank.internal:11434

# ---- Scheduler ----
ECS_SCHEDULER_ENABLED=true
ECS_SCHEDULER_WORKERS=4
ECS_SCHEDULER_TIMEOUT_SECONDS=600
ECS_SCHEDULER_MAX_RETRIES=3

# ---- Connector execution ----
ECS_CONNECTORS_ENABLED=true
ECS_CONNECTOR_TIMEOUT_SECONDS=30
ECS_CONNECTOR_MAX_RETRIES=2
ECS_CONNECTOR_SSL_VERIFY=true
ECS_CONNECTOR_PROXY_URL=

# ---- Logging / monitoring ----
ECS_LOG_LEVEL=INFO
ECS_LOG_FORMAT=json
ECS_LOG_MASK_SECRETS=true
ECS_MONITORING_ENABLED=true

# ---- Predefined-query execution targets (DR-site host/IP lists) ----
ECS_TARGET_OS_SERVERS=
ECS_TARGET_DB_SERVERS=
ECS_TARGET_MW_SERVERS=
ECS_TARGET_APPSEC=

# ---- Reporting ----
ECS_REPORT_EXPORT_PATH=/var/ecs/exports/dr
