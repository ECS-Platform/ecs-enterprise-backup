# ECS environment template — copy to .env and fill in real values.
#   cp .env.example .env
# .env is git-ignored. NEVER commit real secrets. All values below are placeholders.

# ---------------------------------------------------------------------------
# Evidence repository (PostgreSQL) — used by ecs_platform repository + /readyz
# ---------------------------------------------------------------------------
ECS_PG_USER=ecs_user
ECS_PG_PASSWORD=change-me
ECS_PG_DB=ecs_repository

# ---------------------------------------------------------------------------
# Object store (MinIO / S3-compatible)
# ---------------------------------------------------------------------------
MINIO_ACCESS_KEY=change-me
MINIO_SECRET_KEY=change-me

# ---------------------------------------------------------------------------
# LLM / RAG (local Ollama is the default provider)
# ---------------------------------------------------------------------------
ECS_LLM_PROVIDER=ollama
ECS_LLM_MODEL=qwen3:8b
ECS_EMBEDDING_MODEL=nomic-embed-text
ECS_VECTOR_DIM=768
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3:8b
# Optional cloud providers (leave blank to keep disabled)
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Self-hosted demo sources
# ---------------------------------------------------------------------------
GITEA_TOKEN=
SONAR_USER=admin
SONAR_PASSWORD=change-me
JENKINS_USER=admin
JENKINS_TOKEN=change-me

# ---------------------------------------------------------------------------
# SaaS connectors — set <NAME>_ENABLED=true and provide credentials to activate
# ---------------------------------------------------------------------------
ECS_JIRA_ENABLED=false
JIRA_URL=
JIRA_USER=
JIRA_TOKEN=

ECS_CONFLUENCE_ENABLED=false
CONFLUENCE_URL=
CONFLUENCE_USER=
CONFLUENCE_TOKEN=

ECS_GITHUB_ENABLED=false
GITHUB_URL=https://api.github.com
GITHUB_ORG=
GITHUB_TOKEN=

ECS_FIGMA_ENABLED=false
FIGMA_URL=https://api.figma.com
FIGMA_TOKEN=
FIGMA_TEAM_IDS=

ECS_TEAMS_ENABLED=false
ECS_SHAREPOINT_ENABLED=false
MS_GRAPH_URL=https://graph.microsoft.com/v1.0
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
SHAREPOINT_SITE_ID=
