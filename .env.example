# ECS environment template — copy to .env and fill in real values.
#   cp .env.example .env
# .env is git-ignored. NEVER commit real secrets. All values below are placeholders.

# ===========================================================================
# AUTHENTICATION (Phase 1 — Azure AD / OIDC / JWT)
# ===========================================================================
# Master switch. Secure-by-default ON. Set to false only to restore legacy
# (no-auth) behaviour for a controlled demo environment.
ECS_AUTH_ENABLED=true
# Active provider: azure_ad | oidc | dev
ECS_AUTH_PROVIDER=azure_ad

# ---- Azure Active Directory (primary IdP) ----
ECS_AZURE_TENANT_ID=
ECS_AZURE_CLIENT_ID=
# Optional overrides for sovereign/national clouds (else derived from tenant id):
ECS_AZURE_ISSUER=
ECS_AZURE_JWKS_URI=

# ---- Generic OIDC (future IdPs: Okta, Keycloak, ...) ----
ECS_OIDC_ISSUER=
ECS_OIDC_JWKS_URI=
ECS_OIDC_CLIENT_ID=

# ---- JWT validation tuning ----
# Comma-separated accepted audiences (defaults to client id when blank).
ECS_AUTH_ALLOWED_AUDIENCES=
ECS_AUTH_LEEWAY_SECONDS=60
# Claim-name overrides (Azure AD defaults shown).
ECS_AUTH_CLAIM_USER_ID=oid
ECS_AUTH_CLAIM_USERNAME=preferred_username
ECS_AUTH_CLAIM_DISPLAY_NAME=name
ECS_AUTH_CLAIM_EMAIL=email
ECS_AUTH_CLAIM_ROLES=roles
ECS_AUTH_CLAIM_GROUPS=groups

# ---- Local development bypass (DISABLED by default; never enable in prod) ----
ECS_AUTH_DEV_MODE=false
ECS_AUTH_DEV_USER_ID=dev-user
ECS_AUTH_DEV_USERNAME=developer
ECS_AUTH_DEV_DISPLAY_NAME=Local Developer
ECS_AUTH_DEV_EMAIL=developer@localhost
ECS_AUTH_DEV_ROLES=admin
ECS_AUTH_DEV_GROUPS=

# Paths that never require authentication (comma-separated).
ECS_AUTH_PUBLIC_PATHS=/,/login,/healthz,/readyz,/static,/static/ecs,/favicon.ico

# ===========================================================================
# AUTHORIZATION / RBAC (Phase 2)
# ===========================================================================
# Step 2A — route capability predicates through the consolidated PolicyEngine
# legacy-compat path (bug-for-bug parity). Default FALSE.
ECS_RBAC_DELEGATION_ENABLED=false
# Step 2B — RBAC enforcement foundation. Default FALSE: authorization uses the
# caller-supplied role (legacy behaviour). When true, the effective role is derived
# from the AUTHENTICATED principal (app/auth/enforcement.resolve_effective_role) and
# capability decisions run through the parity-tested PolicyEngine path. NOTE: this
# foundation is not yet attached to routes/dashboards/APIs (page & API guards land
# in later steps), so enabling it alone does not gate any endpoint.
RBAC_ENFORCEMENT_ENABLED=false
# Step 2D-critical — enforce authorization on HIGH-RISK MUTATION endpoints only
# (reject-internal, leadership reopen/send-back, escalation, assign-owner, framework
# lifecycle/reuse/onboarding mutations, connector sync, RAG reindex/warm, AI-SDLC
# workflow actions). Default FALSE: those endpoints behave exactly as today. When
# true, they require the authenticated principal to hold the mapped permission
# (browser routes redirect with a notice; JSON APIs return HTTP 403). Builds on the
# Step 2B foundation; enabling it also activates the engine-backed decision path.
RBAC_MUTATION_ENFORCEMENT_ENABLED=false
# Step 2C — enforce DASHBOARD / PAGE access control. Default FALSE: persona
# dashboards behave exactly as today (any role reachable by URL). When true, each
# guarded persona dashboard (CIO / Auditor / Compliance / Security / Vertical /
# Functional) requires the AUTHENTICATED principal's canonical role to be permitted
# for that page (PolicyEngine page catalog); unauthorized browser requests get a
# 403 "Access Denied" page, APIs get 403 JSON. No scope/data/GET/API/login changes.
RBAC_PAGE_ENFORCEMENT_ENABLED=false
# Step 3 — DATA SCOPE FILTERING (final RBAC hardening). Default FALSE: all in-scope
# data is visible exactly as today. When true, dashboard row lists and list/search
# APIs are filtered to the AUTHENTICATED principal's scope (enterprise roles —
# CIO/auditor/compliance/security/admin — see everything; vertical/function/
# application/control roles see only their assignments, derived from principal groups
# like "app:payments-api"). Response schemas are unchanged. Query params are never
# trusted for scope.
RBAC_SCOPE_FILTERING_ENABLED=false

# ===========================================================================
# DURABLE AUDIT TRAIL (Phase 4)
# ===========================================================================
# Workflow audit wiring kill-switch (Phase 4 Step 2). Default FALSE: workflow
# behaviour is byte-for-byte unchanged and no durable workflow audit records are
# written. Set to true to emit durable, attributable audit records (before/after
# state, authenticated actor, request_id) for submit/approve/reject/observation
# lifecycle/escalation. Requires the PostgreSQL evidence repository.
AUDIT_WORKFLOW_ENABLED=false

# Durable observation persistence kill-switch (Phase 4 Step 3). Default FALSE:
# observations remain in-memory (existing behaviour). Set to true to mirror
# observation create/update/close/reopen to the PostgreSQL observations table
# (write-through), hydrate them back into memory on startup so the lifecycle
# survives restart, and enable the one-time in-memory -> durable migration helper.
# Requires the PostgreSQL evidence repository.
OBSERVATIONS_DURABLE_ENABLED=false

# ===========================================================================
# Evidence repository (PostgreSQL)
# ===========================================================================
ECS_PG_USER=ecs_user
ECS_PG_PASSWORD=change-me
ECS_PG_DB=ecs_repository

# ===========================================================================
# Evidence Sufficiency Engine (Phase 5.2-A) — read-only deterministic scoring
# ===========================================================================
# Master flag. Default false. When false the engine computes nothing and ECS
# behavior is unchanged. No LLM, no workflow/dashboard/API/RBAC/auth/RAG impact.
SUFFICIENCY_ENGINE_ENABLED=false

# ===========================================================================
# Evidence Intelligence Foundation (Phase 5.4) — deterministic, non-LLM
# ===========================================================================
# All default false; engines are read-only and compute nothing when off.
# Sufficiency V2 deliberately REUSES SUFFICIENCY_ENGINE_ENABLED above.
EVIDENCE_VERSIONING_ENABLED=false
EVIDENCE_LINEAGE_ENABLED=false
OBSERVATION_READINESS_ENABLED=false
EVIDENCE_REUSE_SCORING_ENABLED=false
EVIDENCE_CHANGE_DETECTION_ENABLED=false
EVIDENCE_QUERY_ENABLED=false

# ===========================================================================
# Connectivity Readiness & Connector Certification (Phase 5.3) — deterministic
# ===========================================================================
# Both default false. When false the engines compute nothing and ECS behavior is
# unchanged. No LLM, no production network calls, no connector-runtime changes.
CONNECTIVITY_ASSESSMENT_ENABLED=false
CONNECTOR_CERTIFICATION_ENABLED=false

# ===========================================================================
# Backup / Restore (Phase 5 Step 1) — scripts/backup, scripts/restore
# ===========================================================================
# Output directory for database backups (default: <repo>/backups).
BACKUP_DIR=./backups
# Prune backups older than this many days (0 = keep forever).
BACKUP_RETENTION_DAYS=14
# Connection used by backup/restore scripts (mirrors config/repository.yaml).
# These reuse the SAME values ECS uses for the evidence repository.
ECS_REPO_PG_HOST=localhost
ECS_REPO_PG_PORT=5432
ECS_REPO_PG_DATABASE=ecs_repository
ECS_REPO_PG_USER=ecs_user
ECS_REPO_PG_PASSWORD=change-me

# ===========================================================================
# LLM / RAG (local Ollama default) — not modified in Phase 1
# ===========================================================================
ECS_LLM_PROVIDER=ollama
ECS_LLM_MODEL=qwen3:8b
ECS_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_URL=http://host.docker.internal:11434

# ===========================================================================
# SaaS connectors — set <NAME>_ENABLED=true and provide credentials to activate
# ===========================================================================
ECS_JIRA_ENABLED=false
JIRA_URL=
JIRA_USER=
JIRA_TOKEN=

ECS_GITHUB_ENABLED=false
GITHUB_URL=https://api.github.com
GITHUB_ORG=
GITHUB_TOKEN=
