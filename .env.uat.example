# =============================================================================
# ECS UAT Connector Credentials — EXAMPLE (.env.uat.example)
# =============================================================================
# Copy to a git-ignored `.env.uat` and fill in REAL bank-UAT values there:
#     cp .env.uat.example .env.uat
#     # edit .env.uat with real UAT hosts + READ-ONLY service-account creds
#
# SAFETY:
#   * Placeholders only here — NEVER commit real secrets, hosts, tenant IDs, or IPs.
#   * `.env.uat` must be git-ignored (verify `git status` shows no `.env.uat`).
#   * Use least-privilege, READ-ONLY service accounts for every connector.
#   * Env var names below are the authoritative names read by the adapters
#     (`modules/operations/integrations/*.get_config()`). The Connector Test
#     Workbench shows each field as SET / MISSING (never the value).
#
# Field guide + validation steps: docs/uat_connector_credentials_guide.md
# =============================================================================

# ------------------------------------------------------------------ ServiceNow CMDB
# auth_mode: "oauth" (client_id/secret) OR "basic" (username/password)
ECS_SERVICENOW_BASE_URL=https://<instance>-uat.service-now.example
ECS_SERVICENOW_AUTH_MODE=oauth
ECS_SERVICENOW_CLIENT_ID=<oauth-client-id-from-servicenow-admin>
ECS_SERVICENOW_CLIENT_SECRET=<secret-from-servicenow-oauth-app>
ECS_SERVICENOW_USERNAME=svc_ecs_snow@bank.example
ECS_SERVICENOW_PASSWORD=<secret-service-account-password>
ECS_SERVICENOW_TIMEOUT_SECONDS=30
ECS_SERVICENOW_MAX_RETRIES=2

# ------------------------------------------------------------------ Archer GRC
ECS_ARCHER_BASE_URL=https://archer-uat.example.bank
ECS_ARCHER_API_TOKEN=<secret-archer-api-token>
ECS_ARCHER_TIMEOUT_SECONDS=30

# ------------------------------------------------------------------ Microsoft Graph (shared)
# The 3 Graph connectors (SharePoint/Teams/Outlook) SHARE these tenant/app creds.
ECS_GRAPH_TENANT_ID=<azure-ad-tenant-id-guid>
ECS_GRAPH_CLIENT_ID=<app-registration-client-id-guid>
ECS_GRAPH_CLIENT_SECRET=<secret-from-app-registration>
ECS_GRAPH_SCOPE=https://graph.microsoft.com/.default
ECS_GRAPH_AUTHORITY_URL=https://login.microsoftonline.com
ECS_GRAPH_TIMEOUT_SECONDS=30
ECS_GRAPH_MAX_RETRIES=2

# ---- SharePoint (Graph) ----
ECS_GRAPH_SITE_ID=<sharepoint-site-id>
ECS_GRAPH_DRIVE_ID=<sharepoint-drive-id-optional>
ECS_SHAREPOINT_SITE_HOSTNAME=<tenant>.sharepoint.example
ECS_SHAREPOINT_SITE_PATH=/sites/<evidence-site>
ECS_SHAREPOINT_FOLDER_PATH=<optional-folder-path>

# ---- Teams (Graph) ----
ECS_TEAMS_TEAM_ID=<teams-team-id>
ECS_TEAMS_CHANNEL_ID=<teams-channel-id-optional>
ECS_TEAMS_MESSAGE_LIMIT=50

# ---- Outlook (Graph) ----
ECS_OUTLOOK_USER_ID=svc_ecs_audit@bank.example
ECS_OUTLOOK_MAIL_FOLDER=inbox
ECS_OUTLOOK_MESSAGE_LIMIT=50

# ------------------------------------------------------------------ Jira
ECS_JIRA_BASE_URL=https://jira-uat.example.bank
ECS_JIRA_USERNAME=svc_ecs_jira@bank.example
ECS_JIRA_API_TOKEN=<secret-from-jira-service-account>
ECS_JIRA_PROJECT_KEY=ABC
ECS_JIRA_JQL=
ECS_JIRA_API_VERSION=2
ECS_JIRA_TIMEOUT_SECONDS=30
ECS_JIRA_MAX_RETRIES=2

# ------------------------------------------------------------------ Confluence
ECS_CONFLUENCE_BASE_URL=https://confluence-uat.example.bank
ECS_CONFLUENCE_USERNAME=svc_ecs_confluence@bank.example
ECS_CONFLUENCE_API_TOKEN=<secret-from-confluence-service-account>
ECS_CONFLUENCE_SPACE_KEY=SEC
ECS_CONFLUENCE_TIMEOUT_SECONDS=30
ECS_CONFLUENCE_MAX_RETRIES=2

# ------------------------------------------------------------------ SonarQube
ECS_SONARQUBE_BASE_URL=https://sonar-uat.example.bank
ECS_SONARQUBE_TOKEN=<secret-sonarqube-user-token>
ECS_SONARQUBE_PROJECT_KEY=<project-key-optional>
ECS_SONARQUBE_TIMEOUT_SECONDS=30
ECS_SONARQUBE_MAX_RETRIES=2

# ------------------------------------------------------------------ Checkmarx
ECS_CHECKMARX_BASE_URL=https://checkmarx-uat.example.bank
ECS_CHECKMARX_CLIENT_ID=<checkmarx-oauth-client-id>
ECS_CHECKMARX_CLIENT_SECRET=<secret-checkmarx-oauth-secret>
ECS_CHECKMARX_ACCESS_TOKEN=<optional-preissued-token>
ECS_CHECKMARX_TOKEN_URL=<optional-oauth-token-url>
ECS_CHECKMARX_TIMEOUT_SECONDS=30
ECS_CHECKMARX_MAX_RETRIES=2

# ------------------------------------------------------------------ Prisma Cloud
ECS_PRISMA_CLOUD_BASE_URL=https://api-uat.prismacloud.example
ECS_PRISMA_CLOUD_ACCESS_KEY=<prisma-access-key-id>
ECS_PRISMA_CLOUD_SECRET_KEY=<secret-prisma-secret-key>
ECS_PRISMA_CLOUD_TOKEN=<optional-preissued-token>
ECS_PRISMA_CLOUD_TIMEOUT_SECONDS=30
ECS_PRISMA_CLOUD_MAX_RETRIES=2

# ------------------------------------------------------------------ Tripwire
ECS_TRIPWIRE_BASE_URL=https://tripwire-uat.example.bank
ECS_TRIPWIRE_USERNAME=svc_ecs_tripwire
ECS_TRIPWIRE_PASSWORD=<secret-tripwire-service-account-password>
ECS_TRIPWIRE_TIMEOUT_SECONDS=30
ECS_TRIPWIRE_MAX_RETRIES=2
