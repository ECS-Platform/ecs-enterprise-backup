# Python cache
__pycache__/
*.pyc

# macOS
.DS_Store

# IDE
.cursor/
.vscode/

# Python virtual env
venv/
.venv/

# Test cache
.pytest_cache/

# Coverage
.coverage
htmlcov/

# ECS generated runtime files
modules/shared/.ecs_boot_marker
modules/enterprise_grc/reports/ECS_Defect_Report.json
modules/enterprise_grc/reports/ECS_Validation_Report.json

# Logs
*.log

# Environment / secrets
.env
.env.*
!.env.example
# Safe, placeholder-only templates generated by scripts/generate_env_template.py
# (the real .env.uat / .env.prod remain ignored above).
!.env.uat.template
# Placeholder-only UAT connector credentials example (no real secrets; the real
# .env.uat stays ignored by .env.* above).
!.env.uat.example
!.env.prod.template
# Placeholder-only deployment examples for PROD/DR (no real secrets; the real
# .env.prod / .env.dr stay ignored by .env.* above).
!.env.prod.example
!.env.dr.example

# Connector tokens (kept local only; never commit live credentials)
demo-data/.gitea_token
demo-data/*.token

# Database backups (contain sensitive evidence/audit data; never commit)
backups/
*.dump
*.dump.sha256
~$*

# Benchmark report artifacts (regenerated by the benchmark runners)
benchmark_outputs/
benchmarks/output/

# Generated audit LLM benchmark reports (keep dir, ignore outputs)
reports/audit_llm_benchmarks/*.md
reports/audit_llm_benchmarks/*.json

__pycache__/
*.py[cod]
.pytest_cache/

# Runtime generated evidence
data/evidence-objects/evidence/unknown/
