# Python cache
__pycache__/
*.pyc

# macOS
.DS_Store

# IDE
.cursor/
.vscode/

# Python virtual env
venv/
.venv/

# Test cache
.pytest_cache/

# Coverage
.coverage
htmlcov/

# ECS generated runtime files
modules/shared/.ecs_boot_marker
modules/enterprise_grc/reports/ECS_Defect_Report.json
modules/enterprise_grc/reports/ECS_Validation_Report.json

# Logs
*.log

# Environment / secrets
.env
.env.*
!.env.example
# Safe, placeholder-only templates generated by scripts/generate_env_template.py
# (the real .env.uat / .env.prod remain ignored above).
!.env.uat.template
!.env.prod.template

# Connector tokens (kept local only; never commit live credentials)
demo-data/.gitea_token
demo-data/*.token

# Database backups (contain sensitive evidence/audit data; never commit)
backups/
*.dump
*.dump.sha256
~$*

# Benchmark report artifacts (regenerated by the benchmark runners)
benchmark_outputs/
benchmarks/output/
