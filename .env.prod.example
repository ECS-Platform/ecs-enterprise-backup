# =============================================================================
# ECS PRODUCTION — Deployment Environment Variables (EXAMPLE)
# =============================================================================
# Copy to a git-ignored `.env.prod` (or inject via vault / K8s secrets) and set
# REAL production values:  cp .env.prod.example .env.prod
#
# SCOPE: these are the DEPLOYMENT-PORTABILITY knobs (application identity, data
# stores, scheduler, connector execution, security). Connector CREDENTIALS live
# in .env.prod.template / your secret store. Moving LOCAL→UAT→PROD→DR requires
# ONLY changing values here — never source code.
#
# SAFETY: placeholders only. NEVER commit real secrets/hosts/IPs. `.env.prod`
# must be git-ignored. Secrets belong in a vault, not in files where possible.
# Validate before deploy:  ECS_ENV=prod ECS_VALIDATE_SECRETS=1 \
#                          python -m config.config_validation prod --check-secrets
# =============================================================================

# ---- Environment selector ----
ECS_ENV=prod

# ---- ECS application identity (must NOT be localhost in prod) ----
ECS_HOST=0.0.0.0
ECS_PORT=8000
ECS_PUBLIC_URL=https://ecs.bank.internal
ECS_BASE_URL=https://ecs.bank.internal
ECS_WEB_WORKERS=4

# ---- Security / TLS ----
ECS_AUTH_ENABLED=true
ECS_LOCAL_AUTH_BYPASS=false
ECS_FORCE_HTTPS=true
ECS_HSTS_ENABLED=true
ECS_SSO_ENABLED=true
ECS_SSO_PROVIDER=saml

# ---- Evidence repository (PostgreSQL) ----
ECS_REPO_PG_HOST=pg.prod.bank.internal
ECS_REPO_PG_PORT=5432
ECS_REPO_PG_DATABASE=ecs_repository
ECS_REPO_PG_USER=ecs_user
ECS_REPO_PG_PASSWORD=<from-vault>
ECS_REPO_PG_SCHEMA=public

# ---- Redis (app cache / scheduler broker) ----
REDIS_HOST=redis.prod.bank.internal
REDIS_PORT=6379
REDIS_SSL=true
REDIS_PASSWORD=<from-vault>

# ---- Object storage (evidence artifacts) ----
ECS_OBJECT_STORE_ENABLED=true
ECS_OBJECT_STORE_PROVIDER=s3
MINIO_ENDPOINT=objectstore.prod.bank.internal:9000
MINIO_BUCKET=ecs-evidence
MINIO_SECURE=true
MINIO_ACCESS_KEY=<from-vault>
MINIO_SECRET_KEY=<from-vault>

# ---- Vector store (RAG embeddings) ----
ECS_VECTOR_PROVIDER=pgvector
ECS_VECTOR_PG_HOST=pgvector.prod.bank.internal
ECS_VECTOR_PG_PORT=5432
ECS_VECTOR_PG_DATABASE=ecs_vectors
ECS_VECTOR_PG_PASSWORD=<from-vault>

# ---- LLM / embeddings (on-prem inference; never host.docker.internal) ----
ECS_LLM_PROVIDER=ollama
ECS_LLM_MODEL=qwen3:8b
OLLAMA_URL=http://llm.prod.bank.internal:11434

# ---- Scheduler ----
ECS_SCHEDULER_ENABLED=true
ECS_SCHEDULER_WORKERS=4
ECS_SCHEDULER_TIMEOUT_SECONDS=600
ECS_SCHEDULER_MAX_RETRIES=3

# ---- Connector execution (global defaults; per-connector creds elsewhere) ----
ECS_CONNECTORS_ENABLED=true
ECS_CONNECTOR_TIMEOUT_SECONDS=30
ECS_CONNECTOR_MAX_RETRIES=2
ECS_CONNECTOR_SSL_VERIFY=true
ECS_CONNECTOR_PROXY_URL=

# ---- Logging / monitoring ----
ECS_LOG_LEVEL=INFO
ECS_LOG_FORMAT=json
ECS_LOG_MASK_SECRETS=true
ECS_MONITORING_ENABLED=true

# ---- Predefined-query execution targets (comma-separated host/IP lists) ----
ECS_TARGET_OS_SERVERS=
ECS_TARGET_DB_SERVERS=
ECS_TARGET_MW_SERVERS=
ECS_TARGET_APPSEC=

# ---- Reporting ----
ECS_REPORT_EXPORT_PATH=/var/ecs/exports/prod
